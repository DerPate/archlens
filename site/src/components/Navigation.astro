---
import LogoMark from "./LogoMark.astro";

const links = [
  ["Overview", "#overview"],
  ["Workflow", "#workflow"],
  ["Capabilities", "#capabilities"],
  ["Install", "#install"],
];
---

<nav class="nav" aria-label="Main navigation">
  <div class="nav-container">
    <a href="#overview" class="nav-logo" aria-label="ArchLens home">
      <LogoMark />
    </a>
    <ul class="nav-menu">
      {links.map(([label, href]) => (
        <li><a href={href} class="nav-link">{label}</a></li>
      ))}
      <li>
        <a href="https://github.com/derPate/spoon-mcp-server" class="nav-link nav-link-strong" target="_blank" rel="noopener noreferrer">GitHub</a>
      </li>
    </ul>
  </div>
</nav>
