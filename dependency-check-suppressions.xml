<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        CVE-2025-67030: plexus-utils Expand.extractFile() directory traversal (CVSS 8.8).
        plexus-utils is a transitive of org.apache.maven:maven-model, used solely for POM parsing.
        The vulnerable Expand class (archive extraction) is never called in this codebase.
        No released fix exists yet — the NVD references a commit hash, not a published version.
        Re-evaluate when plexus-utils ships a patched release.
    -->
    <suppress>
        <notes>Transitive from maven-model (POM parsing only). Expand.extractFile() is never called. No released fix available. CVSS 8.8.</notes>
        <cve>CVE-2025-67030</cve>
    </suppress>

    <!--
        Transitive dependencies pulled in by org.apache.tinkerpop:tinkergraph-gremlin / gremlin-core.
        No patched TinkerPop 3.x release is available. All are low severity (CVSS < 4).
        Re-evaluate when TinkerPop ships a 3.x patch or a stable 4.x release.
    -->

    <!-- CVE-2023-35116: jackson-databind stack overflow via deeply nested input (gremlin-shaded).
         Exploitable only if untrusted arbitrary JSON is deserialized — not the case here. CVSS 2.15. -->
    <suppress>
        <notes>TinkerPop transitive: gremlin-shaded bundles its own jackson; not reachable from our code paths. CVSS 2.15.</notes>
        <cve>CVE-2023-35116</cve>
    </suppress>

    <!-- CVE-2024-29131 / CVE-2024-29133: commons-configuration2 stack overflow via crafted config.
         Configuration is loaded from trusted local files only, not from untrusted input. CVSS 2.9. -->
    <suppress>
        <notes>TinkerPop transitive: commons-configuration2 loaded from trusted sources only. CVSS 2.9.</notes>
        <cve>CVE-2024-29131</cve>
    </suppress>
    <suppress>
        <notes>TinkerPop transitive: commons-configuration2 loaded from trusted sources only. CVSS 2.9.</notes>
        <cve>CVE-2024-29133</cve>
    </suppress>

    <!-- CVE-2025-48734: commons-beanutils class serialisation issue.
         Not exposed to untrusted serialised input in this server. CVSS 1.9. -->
    <suppress>
        <notes>TinkerPop transitive: commons-beanutils not exposed to untrusted serialised input. CVSS 1.9.</notes>
        <cve>CVE-2025-48734</cve>
    </suppress>

</suppressions>
